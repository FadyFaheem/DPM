#Run all API tests
cd infra/api && python -m pytest tests/ -v

#Run API tests with coverage
cd infra/api && python -m pytest tests/ -v --cov=. --cov-report=term-missing

#Run a specific API test file
read -p "Enter test file (e.g., test_auth.py): " tf && cd infra/api && python -m pytest tests/$tf -v

#Run API health tests only
cd infra/api && python -m pytest tests/test_health.py -v

#Run API auth tests only
cd infra/api && python -m pytest tests/test_auth.py -v

#Run API middleware tests only
cd infra/api && python -m pytest tests/test_middleware.py -v

#Run all frontend tests
cd frontend && npx vitest run

#Run frontend tests in watch mode
cd frontend && npx vitest

#Run frontend tests with coverage
cd frontend && npx vitest run --coverage

#Run a specific frontend test file
read -p "Enter test file (e.g., client.test.ts): " tf && cd frontend && npx vitest run $tf

#Run frontend API client tests only
cd frontend && npx vitest run src/__tests__/api/client.test.ts

#Run ALL tests (API + Frontend)
cd infra/api && python -m pytest tests/ -v && cd ../../frontend && npx vitest run

#Install API test dependencies
cd infra/api && pip install -r requirements.txt

#Install frontend dependencies
cd frontend && npm install
