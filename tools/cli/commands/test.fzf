#Run all API tests (Minitest)
cd api && bundle exec rails test

#Run a specific API test file
read -p "Enter test file (e.g., test/controllers/health_controller_test.rb): " tf && cd api && bundle exec rails test "$tf"

#Run all frontend tests
cd frontend && npx vitest run

#Run frontend tests in watch mode
cd frontend && npx vitest

#Run frontend tests with coverage
cd frontend && npx vitest run --coverage

#Run a specific frontend test file
read -p "Enter test file (e.g., client.test.ts): " tf && cd frontend && npx vitest run "$tf"

#Run ALL tests (API + Frontend)
cd api && bundle exec rails test && cd ../frontend && npx vitest run

#Install API dependencies (bundle)
cd api && bundle install

#Install frontend dependencies
cd frontend && npm install
